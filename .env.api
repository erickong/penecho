# Ready-to-use API profile. Copy to .env and replace AI_API_KEY.
# Works from localhost and the LAN by default.
AI_PROVIDER=api
HOST=0.0.0.0
PORT=3888

# Possible values: openai | anthropic
AI_API_FORMAT=openai
AI_API_URL=https://api.openai.com/v1
AI_API_MODEL=gpt-5.6-sol
AI_API_KEY=replace_with_your_api_key
# Known values: low, medium, high, xhigh, max. Other model-specific strings are
# passed through unchanged; unsupported values produce an upstream error.
AI_EFFORT=max

# Anthropic API alternative:
# AI_API_FORMAT=anthropic
# AI_API_URL=https://api.anthropic.com
# AI_API_MODEL=claude-sonnet-5
# AI_API_KEY=replace_with_your_anthropic_api_key

# Also supports OpenAI-format compatible/local endpoints, for example:
# AI_API_URL=http://127.0.0.1:11434/v1
# AI_API_MODEL=your_vision_model

PENECHO_AI_IMAGE_FORMAT=webp
