# Ready-to-use Codex CLI profile. Run `codex login`, then copy to .env.
# No API URL or API key is needed. Works from localhost and the LAN by default.
AI_PROVIDER=codex-cli
HOST=0.0.0.0
PORT=3888
CODEX_CLI_PATH=codex

# Leave empty to use the Codex CLI configured default, or enter a model ID
# accepted by your installed Codex CLI.
CODEX_CLI_MODEL=
# Known values: low | medium | high | xhigh | max; other strings are allowed.
# Empty keeps the Codex CLI default.
AI_EFFORT=
CODEX_CLI_TIMEOUT_SECONDS=120
