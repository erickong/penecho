# Ready-to-use Claude CLI profile. Run `claude auth login`, then copy to .env.
# No API URL or API key is needed. Works from localhost and the LAN by default.
AI_PROVIDER=claude-cli
HOST=0.0.0.0
PORT=3888
CLAUDE_CLI_PATH=claude

# Leave empty to use the Claude CLI configured default. You may also use an
# alias such as sonnet, opus, haiku, or fable, or a full supported model ID.
CLAUDE_CLI_MODEL=
# Known values: low | medium | high | xhigh | max; other strings are allowed.
# Empty keeps the Claude CLI default.
AI_EFFORT=
CLAUDE_CLI_TIMEOUT_SECONDS=120
