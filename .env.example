# PenEcho complete configuration reference
#
# Choose exactly one executor:
#   api        = OpenAI-format, Anthropic-format, compatible, or local HTTP API
#   codex-cli  = installed and authenticated Codex CLI
#   claude-cli = installed and authenticated Claude Code CLI
#
# Fastest source checkout setup:
#   copy .env.api .env       # then replace AI_API_KEY
#   copy .env.codex .env     # after `codex login`
#   copy .env.claude .env    # after `claude auth login`

# -----------------------------------------------------------------------------
# 1. Executor selection (required)
# Possible values: api | codex-cli | claude-cli
# -----------------------------------------------------------------------------
AI_PROVIDER=api

# -----------------------------------------------------------------------------
# 2. Server settings (all executors)
# -----------------------------------------------------------------------------
# 0.0.0.0 allows this computer and LAN devices to connect.
# Use 127.0.0.1 to listen only on this computer.
HOST=0.0.0.0
# Integer from 0 to 65535. 0 asks the OS to choose a free port.
PORT=3888
# Optional data directory for config state and logs. Relative paths use the
# current working directory. Default: ~/.penecho for CLI use, ./logs otherwise.
# PENECHO_STATE_DIR=.penecho

# Optional global reasoning effort. Known values: low | medium | high | xhigh | max
# Other strings are passed through for models that add their own effort levels.
# API mode defaults to max when omitted. CLI modes omit their effort override
# when this is empty, so Codex/Claude keep their own configured defaults.
# Unsupported values are reported by the selected API or CLI.
# AI_EFFORT=

# -----------------------------------------------------------------------------
# 3. API executor — used only when AI_PROVIDER=api
# -----------------------------------------------------------------------------
# Possible values: openai | anthropic. Default example: openai.
AI_API_FORMAT=openai
# OpenAI example: https://api.openai.com/v1
# Anthropic example: https://api.anthropic.com
# Compatible/local example: http://127.0.0.1:11434/v1
AI_API_URL=https://api.openai.com/v1
# Any vision-capable model offered by the selected endpoint.
AI_API_MODEL=gpt-5.6-sol
AI_API_KEY=replace_with_your_api_key
# Image sent to an HTTP API. Possible values: webp | png | jpeg | jpg
# jpg is an alias for jpeg. Default: webp (lossless).
PENECHO_AI_IMAGE_FORMAT=webp

# Anthropic API alternative:
# AI_API_FORMAT=anthropic
# AI_API_URL=https://api.anthropic.com
# AI_API_MODEL=claude-sonnet-5
# AI_API_KEY=replace_with_your_anthropic_api_key

# -----------------------------------------------------------------------------
# 4. Codex CLI executor — used only when AI_PROVIDER=codex-cli
# -----------------------------------------------------------------------------
# Command name or absolute executable path. Default: codex
# CODEX_CLI_PATH=codex
# Optional model override. Leave empty to use the Codex CLI configured default;
# otherwise enter any model ID accepted by your installed Codex CLI.
# CODEX_CLI_MODEL=
# Seconds per model attempt. Number from 10 to 300. Default: 120
# CODEX_CLI_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# 5. Claude CLI executor — used only when AI_PROVIDER=claude-cli
# -----------------------------------------------------------------------------
# Command name or absolute executable path. Default: claude
# CLAUDE_CLI_PATH=claude
# Optional model override. Leave empty to use the Claude CLI configured default.
# Accepted values include aliases such as sonnet, opus, haiku, or fable, and any
# full model ID accepted by your installed Claude CLI.
# CLAUDE_CLI_MODEL=opus # sonnet etc.
# Seconds per model attempt. Number from 10 to 300. Default: 120
# CLAUDE_CLI_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# 6. UI behavior, diagnostics, and local traces (all executors)
# -----------------------------------------------------------------------------
# Initial automatic AI delay in seconds, from 0 to 60. Default: 1.2
# The browser control can select 0–10 seconds for the current saved preference.
# AUTO_AI_DELAY_SECONDS=1.2
# Save localhost-only latest debug artifacts.
# Accepted booleans: true | false | 1 | 0 | yes | no | on | off. Default: false
# PENECHO_DEBUG_ARTIFACTS=false
# Save complete local request traces. Accepted booleans are the same. Default: false
# PENECHO_REQUEST_TRACE=false
# Retained trace directories. Integer from 1 to 1000. Default: 100
# PENECHO_REQUEST_TRACE_LIMIT=100

# -----------------------------------------------------------------------------
# 7. Legacy API names (read for backward compatibility; do not use in new files)
# -----------------------------------------------------------------------------
# OPENAI_API_FORMAT maps to AI_API_FORMAT
# OPENAI_API_URL maps to AI_API_URL
# OPENAI_MODEL maps to AI_API_MODEL
# OPENAI_API_KEY maps to AI_API_KEY
